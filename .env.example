# J.A.R.V.I.S. Mark 13 M-13 OMNI - Variáveis de Ambiente
# ⚠️ IMPORTANTE: NUNCA COMMITAR O ARQUIVO .env REAL!
# COPIE ESTE ARQUIVO PARA .env E PREENCHA COM SUAS CHAVES

# 🔑 API do Google Gemini AI
# Obtenha sua chave em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=COLOQUE_SUA_CHAVE_GEMINI_AQUI

# 📁 Diretório de trabalho (opcional)
# Se não especificado, usará a área de trabalho do usuário
WORKSPACE_PATH=

# ⚙️ Habilitar ações do sistema (true/false)
ENABLE_SYSTEM_ACTIONS=true

# 🌐 Configurações de rede (opcional)
# REQUEST_TIMEOUT=30
# MAX_RETRIES=3

# 📊 Configurações de logging (opcional)
# LOG_LEVEL=INFO
# LOG_FILE=jarvis.log
